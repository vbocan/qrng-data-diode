# QRNG-DD MCP Server Configuration
# Copy this file to .env and adjust values for your deployment.

# --- Required ---

# API key for authenticating with the QRNG Gateway.
# Must be one of the keys listed in the Gateway's QRNG_API_KEYS.
QRNG_GATEWAY_API_KEY=

# --- Optional ---

# Address and port the MCP server listens on (default: 0.0.0.0:8080).
MCP_BIND_ADDR=0.0.0.0:8080

# QRNG Gateway URL to forward requests to (default: http://qrng-gateway:7764).
QRNG_GATEWAY_URL=http://qrng-gateway:7764

# Logging filter using Rust's EnvFilter syntax (default: qrng_mcp=info,rmcp=info).
# Examples: "debug" for all debug, "qrng_mcp=trace" for verbose MCP logging.
RUST_LOG=qrng_mcp=info,rmcp=info
